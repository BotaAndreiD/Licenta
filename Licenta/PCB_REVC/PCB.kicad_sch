		(uuid "9f597070-bc78-4baa-a674-fbbbeb19f644")
	)
	(text "REGCAPA/D decuplate la mase separate prin 100nF pentru stabilitatea LDO-urilor interne de 1.8V. \nCLK la masă activează oscilatorul intern de 614.4kHz. SYNC la VCC menține eșantionarea continuă. \nPinii REFIN liberi permit utilizarea referinței interne de 2.5V (necesită activare software).\n"
		(exclude_from_sim no)
		(at 19.05 228.6 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "a5549c2d-c65b-4ca5-8407-e4e003e61a3d")
	)
