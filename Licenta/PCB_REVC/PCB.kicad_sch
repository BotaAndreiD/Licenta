	(text "Pinii GPIO4-GPIO7 controlează interfața SPI hardware nativă. DOUT/*RDY (MISO) generează întreruperi\nla finalul fiecărei conversii. Pinul 3.3V este lăsat liber pentru a izola complet zgomotul digital \nal microcontrolerului de linia analogică VCC curațată de LDO-ul ADP151.\n"
		(exclude_from_sim no)
		(at 234.442 227.838 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify right)
		)
		(uuid "983a0678-81d7-48c2-ad6b-da9d26dc9a31")
	)
	(text "Socket pentru a putea aplasa esp ul pe PCB-ul mama\n"
		(exclude_from_sim no)
