<Window
  x:Class="ECGMonitor.HistoryWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
  Title="Istoric Înregistrări — CardioMed"
  Height="600"
  Width="860"
  Background="#0D1117"
  WindowStartupLocation="CenterScreen"
  WindowStyle="None"
  ResizeMode="CanResize"
>
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome
      CaptionHeight="40"
      ResizeBorderThickness="6"
      GlassFrameThickness="0"
      CornerRadius="0"
      UseAeroCaptionButtons="False"
    />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <Style x:Key="CaptionBtnStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#8B949E" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Width" Value="44" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Cursor" Value="Arrow" />
      <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#21262D" />
                <Setter Property="Foreground" Value="#E6EDF3" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CaptionCloseBtnStyle" TargetType="Button" BasedOn="{StaticResource CaptionBtnStyle}">
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#E81123" />
          <Setter Property="Foreground" Value="White" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="HistoryHeaderStyle" TargetType="GridViewColumnHeader">
      <Setter Property="Background" Value="#21262D" />
      <Setter Property="Foreground" Value="#8B949E" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="GridViewColumnHeader">
            <Border
              Background="{TemplateBinding Background}"
              BorderBrush="#30363D"
              BorderThickness="0,0,0,1"
              Padding="{TemplateBinding Padding}"
            >
              <ContentPresenter
                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                VerticalAlignment="Center"
              />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HistoryRowStyle" TargetType="ListViewItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#E6EDF3" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="10,10" />
      <Setter Property="BorderBrush" Value="#21262D" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListViewItem">
            <Border
              x:Name="Bd"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              Padding="{TemplateBinding Padding}"
            >
              <GridViewRowPresenter VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#161B22" />
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#1F6FEB" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="40" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Caption bar -->
    <Border Grid.Row="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1">
      <Grid Margin="16,0,0,0">
        <TextBlock
          Text="Istoric Înregistrări — CardioMed"
          Foreground="#8B949E"
          FontSize="12"
          FontFamily="Segoe UI"
          VerticalAlignment="Center"
        />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button
            Content="—"
            Style="{StaticResource CaptionBtnStyle}"
            Click="MinimizeBtn_Click"
          />
          <Button Content="✕" Style="{StaticResource CaptionCloseBtnStyle}" Click="CloseBtn_Click" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="0,0,0,16">
        <TextBlock
          Text="Istoric Înregistrări ECG"
          Foreground="#E6EDF3"
          FontSize="22"
          FontWeight="Bold"
          FontFamily="Segoe UI"
        />
        <TextBlock
          Text="Dă dublu-click pe o înregistrare pentru a o revedea complet."
          Foreground="#8B949E"
          FontSize="11"
          FontFamily="Segoe UI"
          Margin="0,4,0,0"
        />
      </StackPanel>

      <Border Grid.Row="1" Background="#161B22" CornerRadius="10" Padding="2">
      <ListView
        x:Name="SessionsList"
        Background="Transparent"
        BorderThickness="0"
        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
        ItemContainerStyle="{StaticResource HistoryRowStyle}"
        MouseDoubleClick="SessionsList_MouseDoubleClick"
      >
        <ListView.View>
          <GridView ColumnHeaderContainerStyle="{StaticResource HistoryHeaderStyle}">
            <GridViewColumn Header="Pacient" DisplayMemberBinding="{Binding PatientName}" Width="200" />
            <GridViewColumn Header="Data" DisplayMemberBinding="{Binding RecordedAtText}" Width="140" />
            <GridViewColumn Header="Durată" DisplayMemberBinding="{Binding DurationText}" Width="70" />
            <GridViewColumn Header="Puls mediu" DisplayMemberBinding="{Binding AvgHeartRate}" Width="90" />
            <GridViewColumn Header="Ritm" DisplayMemberBinding="{Binding RhythmSummary}" Width="200" />
            <GridViewColumn Header="" Width="50">
              <GridViewColumn.CellTemplate>
                <DataTemplate>
                  <Button
                    Content="🗑"
                    Click="DeleteBtn_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#FF6B6B"
                    FontSize="14"
                    Cursor="Hand"
                    Padding="6,2"
                    ToolTip="Șterge înregistrarea"
                  />
                </DataTemplate>
              </GridViewColumn.CellTemplate>
            </GridViewColumn>
          </GridView>
        </ListView.View>
      </ListView>
      </Border>
    </Grid>
  </Grid>
</Window>
