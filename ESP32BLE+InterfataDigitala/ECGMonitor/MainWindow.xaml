<Window
  x:Class="ECGMonitor.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:oxy="http://oxyplot.org/wpf"
  xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
  Title="CardioMed"
  Height="800"
  Width="1400"
  Background="#0D1117"
  WindowStartupLocation="CenterScreen"
  WindowState="Maximized"
  WindowStyle="None"
  ResizeMode="CanResize"
  StateChanged="Window_StateChanged"
  MinWidth="1000"
  MinHeight="600"
>
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome
      CaptionHeight="56"
      ResizeBorderThickness="6"
      GlassFrameThickness="0"
      CornerRadius="0"
      UseAeroCaptionButtons="False"
    />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <Style x:Key="CaptionBtnStyle" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#8B949E" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Width" Value="44" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Cursor" Value="Arrow" />
      <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#21262D" />
                <Setter Property="Foreground" Value="#E6EDF3" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style
      x:Key="CaptionCloseBtnStyle"
      TargetType="Button"
      BasedOn="{StaticResource CaptionBtnStyle}"
    >
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#E81123" />
          <Setter Property="Foreground" Value="White" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="#161B22" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style x:Key="LabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#8B949E" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="ValueLargeStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#E6EDF3" />
      <Setter Property="FontSize" Value="36" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style x:Key="ValueMedStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#E6EDF3" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="ToolBtnStyle" TargetType="Button">
      <Setter Property="Background" Value="#21262D" />
      <Setter Property="Foreground" Value="#E6EDF3" />
      <Setter Property="BorderBrush" Value="#30363D" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="6"
              Padding="{TemplateBinding Padding}"
            >
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#30363D" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid x:Name="RootGrid">
    <Grid.RowDefinitions>
      <RowDefinition Height="56" />
      <RowDefinition Height="*" />
      <RowDefinition Height="64" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="280" />
    </Grid.ColumnDefinitions>

    <!-- HEADER -->
    <Border
      Grid.Row="0"
      Grid.ColumnSpan="2"
      Background="#161B22"
      BorderBrush="#21262D"
      BorderThickness="0,0,0,1"
    >
      <Grid Margin="20,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock
            Text="ECG"
            Foreground="#58A6FF"
            FontSize="18"
            FontWeight="Bold"
            FontFamily="Segoe UI"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text=" MONITOR"
            Foreground="#E6EDF3"
            FontSize="18"
            FontWeight="Bold"
            FontFamily="Segoe UI"
            VerticalAlignment="Center"
          />
          <TextBlock
            Text=" — Sistem de Monitorizare Cardiacă"
            Foreground="#8B949E"
            FontSize="12"
            FontFamily="Segoe UI"
            VerticalAlignment="Center"
            Margin="12,0,0,0"
          />
        </StackPanel>

        <StackPanel
          Grid.Column="2"
          Orientation="Horizontal"
          VerticalAlignment="Center"
          HorizontalAlignment="Right"
        >
          <Ellipse
            x:Name="StatusDot"
            Width="8"
            Height="8"
            Fill="#3FB950"
            Margin="0,0,8,0"
            VerticalAlignment="Center"
          />
          <TextBlock
            x:Name="HeaderTime"
            Text="00:00:00"
            Foreground="#8B949E"
            FontSize="12"
            FontFamily="Segoe UI"
            VerticalAlignment="Center"
            Margin="0,0,16,0"
          />
          <Button
            Content="—"
            Style="{StaticResource CaptionBtnStyle}"
            Click="MinimizeBtn_Click"
            Margin="20,0,0,0"
          />
          <Button
            x:Name="MaximizeBtn"
            Content="▢"
            Style="{StaticResource CaptionBtnStyle}"
            Click="MaximizeBtn_Click"
          />
          <Button
            Content="✕"
            Style="{StaticResource CaptionCloseBtnStyle}"
            Click="CloseBtn_Click"
          />
        </StackPanel>
      </Grid>
    </Border>

    <!-- MAIN PLOT AREA -->
    <Grid Grid.Row="1" Grid.Column="0" Margin="16,16,8,8">
      <Border Style="{StaticResource CardStyle}" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock
              Text="LEAD I"
              Foreground="#8B949E"
              FontSize="11"
              FontFamily="Segoe UI"
              FontWeight="SemiBold"
              VerticalAlignment="Center"
            />
            <Border Background="#21262D" CornerRadius="4" Padding="8,2" Margin="12,0,0,0">
              <TextBlock
                Text="25 mm/s  |  10 mm/mV"
                Foreground="#58A6FF"
                FontSize="10"
                FontFamily="Segoe UI"
              />
            </Border>
            <Border x:Name="LegendPanel" Background="Transparent" Margin="16,0,0,0">
              <StackPanel Orientation="Horizontal">
                <Ellipse
                  Width="8"
                  Height="8"
                  Fill="#FF5050"
                  Margin="0,0,4,0"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="R"
                  Foreground="#8B949E"
                  FontSize="10"
                  FontFamily="Segoe UI"
                  VerticalAlignment="Center"
                  Margin="0,0,10,0"
                />
                <Ellipse
                  Width="8"
                  Height="8"
                  Fill="#FFD232"
                  Margin="0,0,4,0"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="P"
                  Foreground="#8B949E"
                  FontSize="10"
                  FontFamily="Segoe UI"
                  VerticalAlignment="Center"
                  Margin="0,0,10,0"
                />
                <Ellipse
                  Width="8"
                  Height="8"
                  Fill="#FF8C00"
                  Margin="0,0,4,0"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="Q/S"
                  Foreground="#8B949E"
                  FontSize="10"
                  FontFamily="Segoe UI"
                  VerticalAlignment="Center"
                  Margin="0,0,10,0"
                />
                <Ellipse
                  Width="8"
                  Height="8"
                  Fill="#50C8FF"
                  Margin="0,0,4,0"
                  VerticalAlignment="Center"
                />
                <TextBlock
                  Text="T"
                  Foreground="#8B949E"
                  FontSize="10"
                  FontFamily="Segoe UI"
                  VerticalAlignment="Center"
                />
              </StackPanel>
            </Border>
          </StackPanel>
          <oxy:PlotView Grid.Row="1" x:Name="PlotView" Background="Transparent" />
        </Grid>
      </Border>
    </Grid>

    <Viewbox
      Grid.Row="1"
      Grid.RowSpan="2"
      Grid.Column="1"
      Margin="8,16,16,16"
      Stretch="Uniform"
      StretchDirection="Both"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
    >
      <StackPanel Width="280">
        <!-- Puls -->
        <!-- Puls -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="PULS" Style="{StaticResource LabelStyle}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
              <TextBlock
                x:Name="HRValue"
                Text="--"
                Style="{StaticResource ValueLargeStyle}"
                Foreground="#FF6B6B"
              />
              <TextBlock
                Text=" bpm"
                Foreground="#8B949E"
                FontSize="14"
                FontFamily="Segoe UI"
                VerticalAlignment="Bottom"
                Margin="4,0,0,6"
              />
            </StackPanel>
            <ProgressBar
              x:Name="HRBar"
              Minimum="40"
              Maximum="180"
              Value="70"
              Height="4"
              Background="#21262D"
              Margin="0,8,0,10"
            >
              <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                  <Setter Property="Foreground" Value="#FF6B6B" />
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                          <Border x:Name="PART_Track">
                            <Border
                              x:Name="PART_Indicator"
                              Background="{TemplateBinding Foreground}"
                              HorizontalAlignment="Left"
                              CornerRadius="2"
                            />
                          </Border>
                        </Border>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ProgressBar.Style>
            </ProgressBar>

            <!-- Mini grafic trend HR -->
            <TextBlock
              Text="TREND 60s"
              Foreground="#484F58"
              FontSize="10"
              FontFamily="Segoe UI"
              FontWeight="SemiBold"
              Margin="0,0,0,4"
            />
            <Canvas x:Name="HRTrendCanvas" Height="40" Background="#0D1117" ClipToBounds="True">
              <Rectangle Width="248" Height="40" Fill="#0D1117" Canvas.Left="0" Canvas.Top="0" />
            </Canvas>
          </StackPanel>
        </Border>

        <!-- Status Ritm -->
        <Border
          x:Name="RitmBorder"
          Style="{StaticResource CardStyle}"
          Margin="0,0,0,10"
          Background="#0F2A1A"
        >
          <StackPanel>
            <TextBlock Text="RITM CARDIAC" Style="{StaticResource LabelStyle}" Margin="0,0,0,6" />
            <TextBlock
              x:Name="RitmText"
              Text="NORMAL"
              Foreground="#3FB950"
              FontSize="20"
              FontWeight="Bold"
              FontFamily="Segoe UI"
            />
            <TextBlock
              x:Name="RitmSubtext"
              Text="Ritm sinusal regulat"
              Foreground="#8B949E"
              FontSize="11"
              FontFamily="Segoe UI"
              Margin="0,4,0,0"
            />
          </StackPanel>
        </Border>

        <!-- Calitate electrozi -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock
              Text="CALITATE SEMNAL"
              Style="{StaticResource LabelStyle}"
              Margin="0,0,0,8"
            />
            <StackPanel Orientation="Horizontal">
              <Ellipse
                x:Name="QualityDot"
                Width="10"
                Height="10"
                Fill="#3FB950"
                Margin="0,0,8,0"
                VerticalAlignment="Center"
              />
              <TextBlock
                x:Name="QualityText"
                Text="Semnal Bun"
                Foreground="#3FB950"
                FontSize="14"
                FontWeight="SemiBold"
                FontFamily="Segoe UI"
                VerticalAlignment="Center"
              />
            </StackPanel>
            <TextBlock
              x:Name="QualitySubtext"
              Text="Electrozi conectati corect"
              Foreground="#8B949E"
              FontSize="11"
              FontFamily="Segoe UI"
              Margin="0,4,0,0"
            />
          </StackPanel>
        </Border>

        <!-- Intervale -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="INTERVALE" Style="{StaticResource LabelStyle}" Margin="0,0,0,10" />

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock
                Grid.Column="0"
                Text="PR"
                Foreground="#FFD232"
                FontSize="13"
                FontFamily="Segoe UI"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
              />
              <TextBlock
                x:Name="PRValue"
                Grid.Column="1"
                Text="--"
                Foreground="#E6EDF3"
                FontSize="16"
                FontWeight="Bold"
                FontFamily="Segoe UI"
                Margin="0,0,4,0"
              />
              <TextBlock
                Grid.Column="2"
                Text="ms"
                Foreground="#8B949E"
                FontSize="11"
                FontFamily="Segoe UI"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              />
            </Grid>

            <Grid Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock
                Grid.Column="0"
                Text="QRS"
                Foreground="#FF8C00"
                FontSize="13"
                FontFamily="Segoe UI"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
              />
              <TextBlock
                x:Name="QRSValue"
                Grid.Column="1"
                Text="--"
                Foreground="#E6EDF3"
                FontSize="16"
                FontWeight="Bold"
                FontFamily="Segoe UI"
                Margin="0,0,4,0"
              />
              <TextBlock
                Grid.Column="2"
                Text="ms"
                Foreground="#8B949E"
                FontSize="11"
                FontFamily="Segoe UI"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              />
            </Grid>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock
                Grid.Column="0"
                Text="QTc"
                Foreground="#50C8FF"
                FontSize="13"
                FontFamily="Segoe UI"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
              />
              <TextBlock
                x:Name="QTcValue"
                Grid.Column="1"
                Text="--"
                Foreground="#E6EDF3"
                FontSize="16"
                FontWeight="Bold"
                FontFamily="Segoe UI"
                Margin="0,0,4,0"
              />
              <TextBlock
                Grid.Column="2"
                Text="ms"
                Foreground="#8B949E"
                FontSize="11"
                FontFamily="Segoe UI"
                VerticalAlignment="Bottom"
                Margin="0,0,0,2"
              />
            </Grid>
          </StackPanel>
        </Border>

        <!-- Extrasistole -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="EXTRASISTOLE" Style="{StaticResource LabelStyle}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
              <TextBlock
                x:Name="ExtrasistoleValue"
                Text="0"
                Style="{StaticResource ValueMedStyle}"
                Foreground="#D2A8FF"
              />
              <TextBlock
                Text=" total sesiune"
                Foreground="#8B949E"
                FontSize="13"
                FontFamily="Segoe UI"
                VerticalAlignment="Bottom"
                Margin="4,0,0,4"
              />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- HRV -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="HRV — SDNN" Style="{StaticResource LabelStyle}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
              <TextBlock
                x:Name="HRVValue"
                Text="--"
                Style="{StaticResource ValueMedStyle}"
                Foreground="#79C0FF"
              />
              <TextBlock
                Text=" ms"
                Foreground="#8B949E"
                FontSize="13"
                FontFamily="Segoe UI"
                VerticalAlignment="Bottom"
                Margin="4,0,0,4"
              />
            </StackPanel>
            <TextBlock
              x:Name="HRVStatus"
              Text="--"
              Foreground="#8B949E"
              FontSize="11"
              FontFamily="Segoe UI"
              Margin="0,4,0,0"
            />
          </StackPanel>
        </Border>

        <!-- Amplitudine R -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="AMPLITUDINE R" Style="{StaticResource LabelStyle}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
              <TextBlock
                x:Name="RAmplValue"
                Text="--"
                Style="{StaticResource ValueMedStyle}"
                Foreground="#FFA657"
              />
              <TextBlock
                Text=" mV"
                Foreground="#8B949E"
                FontSize="13"
                FontFamily="Segoe UI"
                VerticalAlignment="Bottom"
                Margin="4,0,0,4"
              />
            </StackPanel>
            <TextBlock
              x:Name="RAmplStatus"
              Text="--"
              Foreground="#8B949E"
              FontSize="11"
              FontFamily="Segoe UI"
              Margin="0,4,0,0"
            />
          </StackPanel>
        </Border>

        <!-- Segment ST -->
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
          <StackPanel>
            <TextBlock Text="SEGMENT ST" Style="{StaticResource LabelStyle}" Margin="0,0,0,6" />
            <StackPanel Orientation="Horizontal">
              <TextBlock
                x:Name="STValue"
                Text="--"
                Style="{StaticResource ValueMedStyle}"
                Foreground="#79C0FF"
              />
            </StackPanel>
            <TextBlock
              x:Name="STStatus"
              Text="--"
              Foreground="#8B949E"
              FontSize="11"
              FontFamily="Segoe UI"
              Margin="0,4,0,0"
            />
          </StackPanel>
        </Border>
      </StackPanel>
    </Viewbox>
    <!-- BOTTOM TOOLBAR - latimea graficului, se opreste la marginea panoului lateral -->
    <Border
      Grid.Row="2"
      Grid.Column="0"
      Background="#161B22"
      BorderBrush="#21262D"
      BorderThickness="0,1,0,0"
    >
      <Grid Margin="20,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Left controls -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Button
            x:Name="PlayPauseBtn"
            Content="⏸  PAUSE"
            Style="{StaticResource ToolBtnStyle}"
            Click="PlayPauseBtn_Click"
            Margin="0,0,8,0"
          />
          <Button
            Content="🕘  Istoric"
            Style="{StaticResource ToolBtnStyle}"
            Click="HistoryBtn_Click"
          />
        </StackPanel>

        <!-- Center - Speed control -->
        <StackPanel
          Grid.Column="1"
          Orientation="Horizontal"
          VerticalAlignment="Center"
          HorizontalAlignment="Center"
        >
          <TextBlock
            Text="Viteza:"
            Foreground="#8B949E"
            FontSize="12"
            FontFamily="Segoe UI"
            VerticalAlignment="Center"
            Margin="0,0,8,0"
          />
          <Button
            Content="0.5x"
            Style="{StaticResource ToolBtnStyle}"
            Click="Speed_Click"
            Tag="2"
            Margin="0,0,4,0"
          />
          <Button
            Content="1x"
            Style="{StaticResource ToolBtnStyle}"
            Click="Speed_Click"
            Tag="4"
            Margin="0,0,4,0"
          />
          <Button
            Content="2x"
            Style="{StaticResource ToolBtnStyle}"
            Click="Speed_Click"
            Tag="8"
            Margin="0,0,16,0"
          />
          <TextBlock
            Text="Fereastra:"
            Foreground="#8B949E"
            FontSize="12"
            FontFamily="Segoe UI"
            VerticalAlignment="Center"
            Margin="0,0,8,0"
          />
          <Button
            Content="5s"
            Style="{StaticResource ToolBtnStyle}"
            Click="Window_Click"
            Tag="640"
            Margin="0,0,4,0"
          />
          <Button
            Content="10s"
            Style="{StaticResource ToolBtnStyle}"
            Click="Window_Click"
            Tag="1280"
            Margin="0,0,4,0"
          />
          <Button
            Content="20s"
            Style="{StaticResource ToolBtnStyle}"
            Click="Window_Click"
            Tag="2560"
            Margin="0,0,4,0"
          />
        </StackPanel>

        <!-- Right - Export -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button
            Content="📄  Export PDF"
            Style="{StaticResource ToolBtnStyle}"
            Click="ExportBtn_Click"
            Foreground="#3FB950"
          />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Disconnect overlay -->
    <Border
      x:Name="DisconnectOverlay"
      Grid.RowSpan="3"
      Grid.ColumnSpan="2"
      Background="#CC0D1117"
      Visibility="Collapsed"
      Panel.ZIndex="100"
    >
      <Border
        Background="#161B22"
        CornerRadius="14"
        BorderBrush="#FF6B6B"
        BorderThickness="1"
        Padding="32"
        Width="420"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
      >
        <StackPanel HorizontalAlignment="Center">
          <Ellipse
            Width="14"
            Height="14"
            Fill="#FF6B6B"
            HorizontalAlignment="Center"
            Margin="0,0,0,14"
          />
          <TextBlock
            Text="Conexiune BLE întreruptă"
            Foreground="#E6EDF3"
            FontSize="20"
            FontWeight="Bold"
            FontFamily="Segoe UI"
            HorizontalAlignment="Center"
          />
          <TextBlock
            Text="Verificați dispozitivul ECG și aduceți-l mai aproape de laptop."
            Foreground="#8B949E"
            FontSize="12"
            FontFamily="Segoe UI"
            HorizontalAlignment="Center"
            TextWrapping="Wrap"
            TextAlignment="Center"
            Margin="0,8,0,16"
          />
          <TextBlock
            x:Name="OverlayStatusText"
            Text="Se reconectează..."
            Foreground="#58A6FF"
            FontSize="12"
            FontFamily="Segoe UI"
            HorizontalAlignment="Center"
          />
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
