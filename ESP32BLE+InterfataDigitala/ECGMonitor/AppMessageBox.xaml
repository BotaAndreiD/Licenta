<Window
  x:Class="ECGMonitor.AppMessageBox"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  WindowStyle="None"
  AllowsTransparency="True"
  Background="Transparent"
  WindowStartupLocation="CenterOwner"
  ResizeMode="NoResize"
  SizeToContent="Height"
  Width="420"
  ShowInTaskbar="False"
>
  <Border
    Background="#161B22"
    CornerRadius="14"
    BorderBrush="#30363D"
    BorderThickness="1"
    Padding="24"
  >
    <Border.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="Black" Opacity="0.5" />
    </Border.Effect>
    <StackPanel>
      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <Ellipse
          x:Name="IconDot"
          Width="10"
          Height="10"
          Fill="#58A6FF"
          VerticalAlignment="Center"
          Margin="0,0,8,0"
        />
        <TextBlock
          x:Name="TitleText"
          FontSize="15"
          FontWeight="Bold"
          Foreground="#E6EDF3"
          FontFamily="Segoe UI"
          VerticalAlignment="Center"
        />
      </StackPanel>
      <TextBlock
        x:Name="MessageText"
        Foreground="#8B949E"
        FontSize="12"
        FontFamily="Segoe UI"
        TextWrapping="Wrap"
        Margin="0,0,0,20"
      />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button
          x:Name="SecondaryBtn"
          Content="Anulează"
          Visibility="Collapsed"
          Click="Secondary_Click"
          Background="#21262D"
          Foreground="#E6EDF3"
          BorderBrush="#30363D"
          BorderThickness="1"
          Padding="14,8"
          Margin="0,0,8,0"
          Cursor="Hand"
        />
        <Button
          x:Name="PrimaryBtn"
          Content="OK"
          Click="Primary_Click"
          Background="#1F6FEB"
          Foreground="White"
          BorderThickness="0"
          Padding="16,8"
          Cursor="Hand"
        />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
