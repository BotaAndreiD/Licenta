<Window
  x:Class="ECGMonitor.SplashScreen"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="CardioMed"
  Height="450"
  Width="600"
  Background="#0D1117"
  WindowStartupLocation="CenterScreen"
  WindowStyle="None"
  ResizeMode="NoResize"
  AllowsTransparency="True"
>
  <Border Background="#0D1117" CornerRadius="16" BorderBrush="#21262D" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="55" />
      </Grid.RowDefinitions>

      <Image
        Grid.Row="0"
        Source="pack://application:,,,/Sigla.png"
        Width="240"
        Height="240"
        Margin="0,16,0,4"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        RenderOptions.BitmapScalingMode="HighQuality"
      />

      <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top">
        <TextBlock HorizontalAlignment="Center">
          <Run
            Text="Cardio"
            Foreground="#58A6FF"
            FontSize="34"
            FontWeight="Bold"
            FontFamily="Segoe UI"
          />
          <Run
            Text="Med"
            Foreground="#E6EDF3"
            FontSize="34"
            FontWeight="Bold"
            FontFamily="Segoe UI"
          />
        </TextBlock>

        <TextBlock
          Text="Sistem de Monitorizare Cardiacă"
          Foreground="#8B949E"
          FontSize="13"
          FontFamily="Segoe UI"
          HorizontalAlignment="Center"
          Margin="0,2,0,0"
        />
      </StackPanel>

      <StackPanel Grid.Row="2" Margin="48,4,48,12">
        <Border Background="#21262D" CornerRadius="4" Height="4">
          <Border
            x:Name="LoadingBar"
            Background="#58A6FF"
            CornerRadius="4"
            HorizontalAlignment="Left"
            Width="0"
          />
        </Border>
        <TextBlock
          x:Name="LoadingText"
          Text="Se inițializează..."
          Foreground="#8B949E"
          FontSize="11"
          FontFamily="Segoe UI"
          HorizontalAlignment="Center"
          Margin="0,6,0,0"
        />
        <Button
          x:Name="RetryBtn"
          Content="Reîncearcă conectarea"
          Click="RetryBtn_Click"
          Visibility="Collapsed"
          Background="#21262D"
          Foreground="#E6EDF3"
          BorderBrush="#30363D"
          FontFamily="Segoe UI"
          FontSize="11"
          Padding="14,6"
          Margin="0,10,0,0"
          Cursor="Hand"
          HorizontalAlignment="Center"
        />
      </StackPanel>

      <Border
        Grid.Row="3"
        Background="#161B22"
        CornerRadius="0,0,16,16"
        BorderBrush="#21262D"
        BorderThickness="0,1,0,0"
      >
        <Grid Margin="24,0">
          <TextBlock
            Text="© 2026 CardioMed — Dispozitiv de uz medical"
            Foreground="#484F58"
            FontSize="11"
            FontFamily="Segoe UI"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
          />

          <TextBlock
            Text="v1.0  —  Universitatea Tehnică"
            Foreground="#484F58"
            FontSize="11"
            FontFamily="Segoe UI"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
          />
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
