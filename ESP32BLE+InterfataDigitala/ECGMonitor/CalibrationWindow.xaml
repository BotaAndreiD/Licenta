<Window
  x:Class="ECGMonitor.CalibrationWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="CardioMed — Calibrare"
  Height="620"
  Width="860"
  Background="#0D1117"
  WindowStartupLocation="CenterScreen"
  WindowStyle="None"
  ResizeMode="NoResize"
  AllowsTransparency="True"
  MouseLeftButtonDown="Window_MouseLeftButtonDown"
>
  <Border Background="#0D1117" CornerRadius="12" BorderBrush="#21262D" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="56" />
        <RowDefinition Height="*" />
        <RowDefinition Height="72" />
      </Grid.RowDefinitions>

      <!-- Header -->
      <Border
        Grid.Row="0"
        Background="#161B22"
        CornerRadius="12,12,0,0"
        BorderBrush="#21262D"
        BorderThickness="0,0,0,1"
      >
        <Grid Margin="24,0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock
              Text="❤"
              Foreground="#FF6B6B"
              FontSize="18"
              Margin="0,0,10,0"
              VerticalAlignment="Center"
            />
            <TextBlock
              Text="CardioMed"
              Foreground="#58A6FF"
              FontSize="16"
              FontWeight="Bold"
              FontFamily="Segoe UI"
              VerticalAlignment="Center"
            />
            <TextBlock
              Text=" — Configurare Electrozi"
              Foreground="#8B949E"
              FontSize="13"
              FontFamily="Segoe UI"
              VerticalAlignment="Center"
              Margin="6,0,0,0"
            />
          </StackPanel>
          <TextBlock
            x:Name="StepIndicator"
            Text="Pas 1 din 2"
            Foreground="#8B949E"
            FontSize="12"
            FontFamily="Segoe UI"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
          />
        </Grid>
      </Border>

      <!-- Progress bars -->
      <Rectangle Grid.Row="0" Height="3" VerticalAlignment="Bottom">
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#58A6FF" Offset="0" />
            <GradientStop Color="#3FB950" Offset="1" />
          </LinearGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle
        x:Name="ProgressBar"
        Grid.Row="0"
        Height="3"
        VerticalAlignment="Bottom"
        HorizontalAlignment="Left"
        Width="430"
        Fill="#58A6FF"
      />

      <!-- CONTENT -->
      <Grid Grid.Row="1">
        <!-- STEP 1 — Plasare electrozi -->
        <Grid x:Name="Step1Panel" Visibility="Visible" Margin="32">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="32" />
            <ColumnDefinition Width="320" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock
              Text="Plasarea Electrozilor"
              Foreground="#E6EDF3"
              FontSize="22"
              FontWeight="Bold"
              FontFamily="Segoe UI"
              Margin="0,0,0,8"
            />
            <TextBlock
              Text="Urmați instrucțiunile pentru o înregistrare ECG de calitate."
              Foreground="#8B949E"
              FontSize="13"
              FontFamily="Segoe UI"
              Margin="0,0,0,28"
            />

            <Border Background="#161B22" CornerRadius="10" Padding="20" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal">
                <Border
                  Background="#FF6B6B"
                  CornerRadius="20"
                  Width="36"
                  Height="36"
                  Margin="0,0,14,0"
                >
                  <TextBlock
                    Text="RA"
                    Foreground="White"
                    FontSize="11"
                    FontWeight="Bold"
                    FontFamily="Segoe UI"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock
                    Text="Electrod Drept (RA)"
                    Foreground="#E6EDF3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    FontFamily="Segoe UI"
                  />
                  <TextBlock
                    Text="Încheietura mâinii drepte sau umărul drept"
                    Foreground="#8B949E"
                    FontSize="11"
                    FontFamily="Segoe UI"
                  />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Background="#161B22" CornerRadius="10" Padding="20" Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal">
                <Border
                  Background="#3FB950"
                  CornerRadius="20"
                  Width="36"
                  Height="36"
                  Margin="0,0,14,0"
                >
                  <TextBlock
                    Text="LA"
                    Foreground="White"
                    FontSize="11"
                    FontWeight="Bold"
                    FontFamily="Segoe UI"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock
                    Text="Electrod Stâng (LA)"
                    Foreground="#E6EDF3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    FontFamily="Segoe UI"
                  />
                  <TextBlock
                    Text="Încheietura mâinii stângi sau umărul stâng"
                    Foreground="#8B949E"
                    FontSize="11"
                    FontFamily="Segoe UI"
                  />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Background="#161B22" CornerRadius="10" Padding="20">
              <StackPanel Orientation="Horizontal">
                <Border
                  Background="#58A6FF"
                  CornerRadius="20"
                  Width="36"
                  Height="36"
                  Margin="0,0,14,0"
                >
                  <TextBlock
                    Text="RL"
                    Foreground="White"
                    FontSize="11"
                    FontWeight="Bold"
                    FontFamily="Segoe UI"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock
                    Text="Electrod Referință (RL)"
                    Foreground="#E6EDF3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    FontFamily="Segoe UI"
                  />
                  <TextBlock
                    Text="Coapsa dreaptă/stânga sau glezna dreaptă/stânga"
                    Foreground="#8B949E"
                    FontSize="11"
                    FontFamily="Segoe UI"
                  />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>

          <Border Grid.Column="2" Background="#161B22" CornerRadius="12" Padding="8">
            <StackPanel
              Orientation="Horizontal"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
            >
              <Image
                Source="pack://application:,,,/electrod1.png"
                Stretch="Uniform"
                Width="140"
                Margin="4"
              />
              <Image
                Source="pack://application:,,,/electrod2.png"
                Stretch="Uniform"
                Width="140"
                Margin="4"
              />
            </StackPanel>
          </Border>
        </Grid>

        <!-- STEP 2 — Verificare semnal -->
        <Grid x:Name="Step2Panel" Visibility="Collapsed" Margin="32">
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="580">
            <TextBlock
              Text="Verificare Semnal ECG"
              Foreground="#E6EDF3"
              FontSize="22"
              FontWeight="Bold"
              FontFamily="Segoe UI"
              HorizontalAlignment="Center"
              Margin="0,0,0,8"
            />
            <TextBlock
              Text="Sistemul verifică dacă semnalul recepționat este valid și în parametri normali."
              Foreground="#8B949E"
              FontSize="13"
              FontFamily="Segoe UI"
              HorizontalAlignment="Center"
              TextAlignment="Center"
              Margin="0,0,0,36"
            />

            <!-- Semnal detectat -->
            <Border Background="#161B22" CornerRadius="10" Padding="20" Margin="0,0,0,12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                  Grid.Column="0"
                  Background="#21262D"
                  CornerRadius="20"
                  Width="36"
                  Height="36"
                  Margin="0,0,14,0"
                >
                  <TextBlock
                    Text="〜"
                    Foreground="#58A6FF"
                    FontSize="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock
                    Text="Detecție Semnal"
                    Foreground="#E6EDF3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    FontFamily="Segoe UI"
                  />
                  <TextBlock
                    x:Name="SignalStatus"
                    Text="Se caută semnal ECG..."
                    Foreground="#8B949E"
                    FontSize="11"
                    FontFamily="Segoe UI"
                  />
                </StackPanel>
                <Ellipse
                  x:Name="SignalDot"
                  Grid.Column="2"
                  Width="14"
                  Height="14"
                  Fill="#8B949E"
                  VerticalAlignment="Center"
                />
              </Grid>
            </Border>

            <!-- Amplitudine -->
            <Border Background="#161B22" CornerRadius="10" Padding="20" Margin="0,0,0,12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                  Grid.Column="0"
                  Background="#21262D"
                  CornerRadius="20"
                  Width="36"
                  Height="36"
                  Margin="0,0,14,0"
                >
                  <TextBlock
                    Text="±"
                    Foreground="#58A6FF"
                    FontSize="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock
                    Text="Amplitudine Semnal"
                    Foreground="#E6EDF3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    FontFamily="Segoe UI"
                  />
                  <TextBlock
                    x:Name="AmplitudeStatus"
                    Text="Se verifică amplitudinea..."
                    Foreground="#8B949E"
                    FontSize="11"
                    FontFamily="Segoe UI"
                  />
                </StackPanel>
                <Ellipse
                  x:Name="AmplitudeDot"
                  Grid.Column="2"
                  Width="14"
                  Height="14"
                  Fill="#8B949E"
                  VerticalAlignment="Center"
                />
              </Grid>
            </Border>

            <!-- Sistem gata -->
            <Border Background="#161B22" CornerRadius="10" Padding="20" Margin="0,0,0,32">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border
                  Grid.Column="0"
                  Background="#21262D"
                  CornerRadius="20"
                  Width="36"
                  Height="36"
                  Margin="0,0,14,0"
                >
                  <TextBlock
                    Text="✓"
                    Foreground="#58A6FF"
                    FontSize="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                  />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock
                    Text="Stare Sistem"
                    Foreground="#E6EDF3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    FontFamily="Segoe UI"
                  />
                  <TextBlock
                    x:Name="ReadyStatus"
                    Text="În așteptare..."
                    Foreground="#8B949E"
                    FontSize="11"
                    FontFamily="Segoe UI"
                  />
                </StackPanel>
                <Ellipse
                  x:Name="ReadyDot"
                  Grid.Column="2"
                  Width="14"
                  Height="14"
                  Fill="#8B949E"
                  VerticalAlignment="Center"
                />
              </Grid>
            </Border>

            <TextBlock
              x:Name="OverallStatus"
              Text="Verificare în curs..."
              Foreground="#8B949E"
              FontSize="14"
              FontWeight="SemiBold"
              FontFamily="Segoe UI"
              HorizontalAlignment="Center"
            />
          </StackPanel>
        </Grid>
      </Grid>

      <!-- FOOTER -->
      <Border
        Grid.Row="2"
        Background="#161B22"
        CornerRadius="0,0,12,12"
        BorderBrush="#21262D"
        BorderThickness="0,1,0,0"
      >
        <Grid Margin="24,0">
          <Button
            x:Name="BackBtn"
            Content="← Înapoi"
            Click="BackBtn_Click"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Visibility="Collapsed"
            Background="#21262D"
            Foreground="#8B949E"
            BorderBrush="#30363D"
            BorderThickness="1"
            FontFamily="Segoe UI"
            FontSize="13"
            Padding="20,10"
          >
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}"
                >
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>

          <StackPanel
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
          >
            <Button
              Content="Anulează"
              Click="CancelBtn_Click"
              Background="Transparent"
              Foreground="#8B949E"
              BorderThickness="0"
              FontFamily="Segoe UI"
              FontSize="13"
              Padding="16,10"
              Margin="0,0,8,0"
              Cursor="Hand"
            >
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}"
                  >
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <Button
              x:Name="NextBtn"
              Content="Continuă →"
              Click="NextBtn_Click"
              Background="#238636"
              Foreground="White"
              BorderThickness="0"
              FontFamily="Segoe UI"
              FontSize="13"
              FontWeight="SemiBold"
              Padding="24,10"
              Cursor="Hand"
            >
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border
                    Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}"
                  >
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                      <Setter Property="Background" Value="#2EA043" />
                    </Trigger>
                  </ControlTemplate.Triggers>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
